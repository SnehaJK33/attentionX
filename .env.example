# AttentionX API Keys
# Copy this file to .env and fill in your values
# NEVER commit .env to git

GEMINI_API_KEY=AIzaSyCl_mUjCgBI84AJucujoRPRintf3zu_CIM
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-flash-8b

# Optional performance tuning
# Whisper model: tiny, base, small, medium, large
WHISPER_MODEL=base
# Set language to speed up decoding when known (example: en, hi)
WHISPER_LANGUAGE=
# ffmpeg preset: ultrafast, superfast, veryfast, faster, fast, medium...
ATTENTIONX_ENCODE_PRESET=veryfast
# Number of CPU threads for ffmpeg encoding
ATTENTIONX_ENCODE_THREADS=8
# Optional: enable ffmpeg stream-copy fast cutting (can be less reliable on some files)
ATTENTIONX_USE_FAST_CUT=0
